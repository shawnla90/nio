{
  "hooks": {
    "PreToolCall": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "nio cc status 2>/dev/null || true"
          }
        ]
      }
    ],
    "PostToolCall": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "nio cc turn --agent \"$(echo $CLAUDE_TOOL_OUTPUT | head -c 500)\" 2>/dev/null || true"
          }
        ]
      }
    ],
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "nio cc start 2>/dev/null || true"
          }
        ]
      }
    ],
    "SessionEnd": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "nio cc end 2>/dev/null || true"
          }
        ]
      }
    ]
  }
}
